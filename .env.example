# Supabase database
# Use the Session Pooler connection string for app traffic when possible.
# URL-encode special characters in your password, especially @, :, /, ?, #, and %.
DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:YOUR_PASSWORD@REAL_POOLER_HOST:REAL_POOLER_PORT/postgres?sslmode=require

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_key_here
VOYAGE_API_KEY=your_voyage_key_here

# LLM Synthesis
# Choose one provider: anthropic or openrouter
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=your_claude_model_here
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=your_openrouter_model_here
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=Equity Research

# Finance Data
YFINANCE_CACHE_DIR=./cache/yfinance

# Other
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
